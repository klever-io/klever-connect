# Klever Connect - Node.js Examples Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================
# NETWORK CONFIGURATION
# ============================================================
# Options: mainnet | testnet | devnet | local
NETWORK=testnet

# ============================================================
# WALLET CONFIGURATION
# WARNING: Never hardcode private keys in source code!
# Use environment variables or a secrets manager.
# ============================================================
# Your 64-character hex private key
PRIVATE_KEY=your_64_character_hex_private_key_here

# ============================================================
# TRANSACTION EXAMPLES
# ============================================================
# Recipient address for transfer examples
RECEIVER_ADDRESS=klv1fpwjz234gy8aaae3gx0e8q9f52vymzzn3z5q0s5h60pvktzx0n0qwvtux5

# Amount in KLV (e.g., "1.5" means 1.5 KLV)
TRANSFER_AMOUNT=0.1

# ============================================================
# AUTOMATION - CLAIM REWARDS
# ============================================================
# Minimum KLV balance required before claiming (in KLV units)
CLAIM_THRESHOLD=10

# How often to check for rewards (in milliseconds)
CHECK_INTERVAL_MS=60000

# ============================================================
# AUTOMATION - DELEGATION
# ============================================================
# Validator address to delegate to
VALIDATOR_ADDRESS=klv1fpwjz234gy8aaae3gx0e8q9f52vymzzn3z5q0s5h60pvktzx0n0qwvtux5

# BLS public key of the new validator (for rebalance example)
NEW_VALIDATOR_BLS=your_validator_bls_key_here

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=3000
HOST=0.0.0.0

# ============================================================
# MONITORING
# ============================================================
# How often to poll for new blocks (in milliseconds)
POLL_INTERVAL_MS=4000

# ============================================================
# WEBHOOKS
# ============================================================
WEBHOOK_PORT=3001
# Secret for validating incoming webhook signatures
WEBHOOK_SECRET=change_this_to_a_random_secret_string
