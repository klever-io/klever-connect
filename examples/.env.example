# Copy this file to .env and fill in your values.
# Never commit the real .env file.

# 64-character hex private key (required for most examples)
PRIVATE_KEY=

# KDA asset ID (e.g. MTT-ABCD-1A) — used by assets/asset-trigger.ts
ASSET_ID=

# Deployed smart contract address — used by contracts/*.ts
CONTRACT_ADDRESS=

# Path to compiled .wasm file — used by contracts/deploy-contract.ts
WASM_PATH=

# Path to ABI JSON file — used by contracts/deploy-contract.ts
ABI_PATH=
